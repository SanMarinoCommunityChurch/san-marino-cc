---
import type { ImageLink as ImageLinkType } from "@content/schemaFragments/sanityComponents";
import SanityImage from "@components/SanityImage.astro";

interface Props {
    link: ImageLinkType;
    orientation?: "vertical" | "horizontal";
}

const { link, orientation = "vertical" } = Astro.props;

let href = "#";
if (link.href && "type" in link.href) {
    if (link.href.type === "page") {
        href = link.href.sectionSlug
            ? link.href.pageSlug.fullUrl
            : link.href.pageSlug.current;
    }
} else if (link.href && "slug" in link.href) {
    href = link.href.slug ?? "#";
}
---

<a class="image-link" data-orientation={orientation} href={`/${href}`}>
    <div class="text flow">
        {link.icon && <i class:list={[`fa-duotone fa-${link.icon}`, `icon`]} />}
        <p class="heading">{link.heading}</p>
        {link.description && <p class="description">{link.description}</p>}
    </div>
    <div class="overlay"></div>
    {
        link.image && (
            <SanityImage
                alt={link.image?.asset.altText || ""}
                aspectRatio={orientation === "vertical" ? [4, 6] : [5, 2]}
                class:list={[
                    "image",
                    "image-scale-in",
                    orientation === "vertical"
                        ? "image-vertical"
                        : "image-horizontal",
                ]}
                source={link.image}
                width={orientation === "vertical" ? 400 : 600}
            />
        )
    }
</a>

<style>
    .image-link {
        position: relative;
        text-decoration: none;
        border-radius: var(--rounded-corners);
        font-family: var(--font-secondary);
        font-weight: var(--font-weight-header);
        font-size: var(--step-2);
        line-height: 1.15;
        padding: 2rem;
        transition: all 0.2s ease;
        color: var(--color-white);
        background-color: var(--bg-color);
        display: inline-flex;
        flex-direction: column;
        justify-content: flex-end;
        overflow: hidden;

        &:hover .overlay {
            opacity: 1;
        }

        &:hover .image {
            transform: scale(1.05);
        }

        &:hover .icon {
            transform: translateX(4px);
        }

        &[data-orientation="vertical"] {
            height: 24rem;
        }

        &[data-orientation="horizontal"] {
            padding: 1.5rem;

            & .image {
                filter: saturate(0);
            }

            & .overlay {
                mask-image: linear-gradient(
                    90deg,
                    rgb(0 0 0 / 100%) 45%,
                    rgb(0 0 0 / 40%)
                );
                -webkit-mask-image: linear-gradient(
                    90deg,
                    rgb(0 0 0 / 100%) 45%,
                    rgb(0 0 0 / 40%)
                );
                opacity: 0.8;
            }

            &:hover .overlay {
                opacity: 0.95;
            }
        }
    }

    .icon {
        transition: transform 0.2s ease;
    }

    .text {
        --flow-space: 0.5rem;
        position: relative;
        z-index: 1;
        align-items: flex-start;
    }

    .description {
        font-family: var(--font-primary);
        font-size: var(--step--1);
        line-height: 1.5;
        font-weight: 400;
    }

    .overlay {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        background-color: var(--overlay-color, var(--color-primary-900));
        opacity: 0.9;
        mask-image: linear-gradient(to top, black, transparent);
        -webkit-mask-image: linear-gradient(to top, black, transparent);
        transition: all 0.3s ease;
    }

    .image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: all 0.5s ease;
        z-index: -1;
    }

    @media (max-width: 768px) {
        .text {
            font-size: var(--step-3);
        }
    }
</style>
