<style>
    .logo {
        color: var(--color-primary-800);
        display: block;
    }

    .logo:hover {
        opacity: 0.7;
    }

    .logo img {
        max-width: 280px;
        height: auto;
        position: relative;
        top: -1px;
    }

    .header {
        position: sticky;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
    }

    .header.cluster {
        --justify: space-between;
    }

    .site-nav {
        --box-shadow: 0px 4px 16px rgba(0, 0, 0, 0.1);
        position: relative;
        display: grid;
        column-gap: 0.5rem;
        row-gap: 0;
        grid-template-columns: 1fr 2fr 1fr;
        justify-content: center;
        align-items: center;
        background-color: var(--color-white);
        padding-block: 1rem;
        padding-inline: var(--space-l);
        box-shadow: var(--box-shadow);
        z-index: 100;
        transition: box-shadow 0.2s ease;

        & .header-buttons {
            justify-self: end;
        }

        /* & > * {
            position: relative;
            z-index: 50;
        } */
    }

    .main-nav .cluster {
        --justify: center;

        & li:last-of-type {
