    .rule {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        width: 100%;
        z-index: 51;
        opacity: 0.15;
        height: 1px;
        background-color: var(--color-primary-500);
        transition: opacity 0.3s ease 0.1s;
    }

    @media (max-width: 1024px) {
        .nav-subgrid {
            padding-inline: 0;
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .img-link {
            display: none;
        }

        .nav-utilities ul {
            grid-template-columns: 1fr;
            gap: 1rem;
        }
    }

    @media (max-width: 870px) {
        .main-nav {
            display: none;
        }

        .header-buttons {
            grid-column: 3;
        }
    }

    @media (max-width: 768px) {
        .site-nav {
            grid-template-columns: 1fr 1fr;
        }

        .header-buttons {
            grid-column: 2;
        }

        .nav-grid ul {
            font-size: var(--step-1);
        }

        .nav-grid.content-wrapper {
            padding-inline: 2rem;
        }

        .nav-grid ul.flow {
            --flow-space: 1rem;
        }
    }

    @media (max-width: 640px) {
        .site-nav {
            padding-inline: 1rem;
        }

        .logo img {
            max-width: 240px;
        }
    }

    @media (max-width: 480px) {
        .give {
            display: none;
