---
import { getCollection, getEntry } from "astro:content";
import Button from "@components/Button.astro";
import FullNavigation from "./FullNavigation.astro";
import { NAVIGATION_IDS } from "@utils/dicts";
import type { NavigationSection } from "@content/navigation";
import PopoverMenu from "./PopoverMenu.vue";
import { buildNavHref } from "@utils/buildNavHref";
import { urlForImage } from "@lib/sanity/urlForImage";

const navigation = await getCollection("navigation");
const siteSettings = await getEntry("siteSettings", "siteSettings");

const mainNav = navigation.find((item) => item.id === NAVIGATION_IDS.main);
---

<header class="header">
    <div class="site-nav">
        <div>
            <a class="font-header logo" href="/">
                {
                    siteSettings?.data.logo ? (
                        <img
                            alt="San Marino Community Church logo"
                            decoding="auto"
                            loading="eager"
                            src={urlForImage(siteSettings.data.logo)
                                .width(600)
                                .auto("format")
                                .url()}
                            width={600}
                        />
                    ) : (
                        <span>San Marino Community Church</span>
                    )
                }
            </a>
        </div>
        <nav class="main-nav">
            <ul class="cluster">
                {
                    mainNav?.data.entries.map((navItem, index) => (
                        <li>
                            <Button
                                href={buildNavHref(navItem)}
                                style={index == 1 ? "solid" : "nav"}
                                theme={index == 1 ? "primary-2" : "neutral"}
                            >
                                {(navItem as NavigationSection).name}
                                {index === 1 && (
                                    <svg fill="var(--color-primary-50)" height="18" style="margin: 0;" viewBox="0 0 576 512" width="18" xmlns="http://www.w3.org/2000/svg"><defs><style>.fa-secondary{opacity:.4}</style></defs><path class="fa-primary" d="M576 128c0-11.8-6.5-22.6-16.9-28.2s-23-5-32.9 1.6L384 196.2V315.8l142.2 94.8c9.8 6.5 22.4 7.2 32.9 1.6s16.9-16.4 16.9-28.2V128z"/><path class="fa-secondary" d="M0 128C0 92.7 28.7 64 64 64H320c35.3 0 64 28.7 64 64V384c0 35.3-28.7 64-64 64H64c-35.3 0-64-28.7-64-64V128z"/></svg>
                                )}
                            </Button>
                        </li>
                    ))
                }
            </ul>
        </nav>
        <div class="header-buttons cluster">
            <Button className="give" href="/giving" theme="secondary"
                >Give</Button
            >
            <PopoverMenu client:load>
                <FullNavigation />
            </PopoverMenu>
        </div>
        <div class="rule"></div>
    </div>
