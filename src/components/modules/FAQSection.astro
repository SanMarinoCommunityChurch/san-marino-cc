---
import type {
    FAQSection as FAQSectionType,
    LinkReference,
} from "@content/schemaFragments/sanityComponents";
import ImageLink from "@components/ImageLink.astro";
import { PortableText } from "astro-portabletext";
import SanityImage from "@components/SanityImage.astro";
import { buildNavHref } from "@utils/buildNavHref";

interface Props {
    module: FAQSectionType;
}

const { module } = Astro.props;
---

<section class="faq-section with-sidebar">
    <div class="faq flow">
        {
            module?.items.map((item) => (
                <details>
                    <summary class="disclosure-button">
                        <div class="question-wrapper">
                            {item.question}
                            <svg
                                aria-hidden="true"
                                class="chevron"
                                fill="var(--svg-fill)"
                                height="18"
                                viewBox="0 0 320 512"
                                width="18"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path d="M305 239c9.4 9.4 9.4 24.6 0 33.9L113 465c-9.4 9.4-24.6 9.4-33.9 0s-9.4-24.6 0-33.9l175-175L79 81c-9.4-9.4-9.4-24.6 0-33.9s24.6-9.4 33.9 0L305 239z" />
                            </svg>
                        </div>
                    </summary>
                    <div class="answer-wrapper text">
                        <PortableText value={item.answer} />
                    </div>
                </details>
            ))
        }
    </div>
    <div class="sidebar">
        <div class="heading">{module?.sidebar.heading}</div>
        <ul class="flow items image-links">
            {
                module?.sidebar.links.map((link) => (
                    <Fragment>
                        <ImageLink link={link} orientation="horizontal" />
                        {/* <li class="link-item">
                            <a href={buildNavHref(link.href as LinkReference)}>
                                <div class="text flow">
                                    {link.icon && (
                                        <i
                                            class:list={`fa-duotone fa-${link.icon}`}
                                        />
                                    )}
                                    <div class="item-heading">
                                        {link.heading}
                                    </div>
                                    <p>{link.description}</p>
                                </div>
                                <div class="overlay" />
                                {link.image && (
                                    <SanityImage
                                        alt={link.image.asset.altText || ""}
                                        aspectRatio={[5, 2]}
                                        class:list={[
                                            "image-scale-in",
                                            "link-item-image",
                                        ]}
                                        source={link.image}
                                        width={600}
                                    />
                                )}
                            </a>
                        </li> */}
                    </Fragment>
                ))
            }
        </ul>
    </div>
</section>

<style>
    .faq.flow {
        gap: 1rem;
    }

    :global(.faq .text ul) {
        list-style: disc;
        padding-left: 2rem;
    }

    :global(.faq .text ul > * + *) {
        margin-top: 1rem;
    }

    :global(.faq .text > * + *) {
        margin-top: 1rem;
    }

    :global(.faq .text a) {
        color: var(--color-primary-800);
    }

    details[open] {
        & .chevron {
            transform: rotate(90deg);
        }
    }

    .question-wrapper {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: var(--font-secondary);
        font-weight: var(--font-weight-semi);
        background-color: var(--color-primary-100);
        color: var(--color-primary-800);
        line-height: 1.3;
        padding: 1.25rem 1.75rem;
        border-radius: var(--rounded-corners);
        font-size: var(--step-1);
        width: 100%;
        transition: background-color 0.2s ease;

        &:hover {
            background-color: var(--color-primary-200);
        }
    }

    .answer-wrapper {
        padding: 2rem;
    }

    .chevron {
        --svg-fill: var(--color-primary-400);
        transform: var(--disclosure-toggle);
        transition: transform 0.2s ease;
    }

    .sidebar {
        position: sticky;
        top: 8rem;
        align-self: flex-start;

        & .heading {
            font-family: var(--font-secondary);
            font-weight: var(--font-weight-header);
            color: var(--color-header-text);
            line-height: 1.2;
            font-size: var(--step-2);
            margin-bottom: 2rem;
        }
    }

    .link-item {
        & a {
            display: inline-block;
            position: relative;
            text-decoration: none;
            color: white;
            padding: 1.5rem;
            border-radius: var(--rounded-corners);
            overflow: hidden;

            &:hover .overlay {
                opacity: 0.95;
            }

            &:hover .link-item-image {
                transform: scale(1.03);
            }
        }

        & .text {
            --flow-space: 0.5rem;
            align-items: flex-start;
            position: relative;
            z-index: 1;

            & .item-heading {
                font-family: var(--font-secondary);
                font-size: var(--step-1);
                font-weight: var(--font-weight-header);
            }

            & p {
                font-size: var(--step--1);
            }
        }

        & .overlay {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            background-color: var(--overlay-color, var(--color-primary-900));
            opacity: 0.8;
            mask-image: linear-gradient(
                to right,
                black 45%,
                rgba(0, 0, 0, 0.4)
            );
            -webkit-mask-image: linear-gradient(
                to right,
                black 45%,
                rgba(0, 0, 0, 0.4)
            );
            transition: all 0.2s ease;
        }

        &:nth-child(2) {
            --overlay-color: #115e59;
        }

        &:nth-child(3) {
            --overlay-color: #c06507;
        }
    }

    .link-item-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: all 0.4s ease;
        z-index: -1;
        filter: saturate(0);
    }

    @media (max-width: 640px) {
        .answer-wrapper {
            padding: 2rem 1rem;
        }

        .question-wrapper {
            gap: 1rem;
        }
    }
</style>
