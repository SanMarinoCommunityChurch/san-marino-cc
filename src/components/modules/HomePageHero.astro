---
import { type CollectionEntry, getEntry } from "astro:content";
import Button from "@components/Button.astro";
import FeaturedAnnouncement from "@components/FeaturedAnnouncement.astro";
import { type HomeHero as HomeHeroType } from "@content/schemaFragments/sanityComponents";
import fallbackImg from "@assets/images/church-front.jpg";
import { getImage } from "astro:assets";

interface Props {
    module: HomeHeroType;
}

const { module } = Astro.props;

const imagePoster = await getImage({
    src: fallbackImg,
    width: 1200,
    height: 675,
    format: "webp",
});

const featuredLinks: (CollectionEntry<"events"> | CollectionEntry<"posts">)[] =
    [];

if (
    module.showFeaturedAnnouncement &&
    module.featuredAnnouncement?.items.length
) {
    for (const item of module.featuredAnnouncement.items) {
        const ref = await getEntry(
            item.type === "event" ? "events" : "posts",
            item._id,
        );
        if (ref) {
            featuredLinks.push(ref);
        }
    }
}
---

<article class="hero">
    <div class="content-wrapper flow">
        <div>
            {module.eyebrow && <p class="small-title">{module.eyebrow}</p>}
            <h1 class="text-step-8 color-white">{module.heading}</h1>
        </div>
        <p>{module.text}</p>
        <div class="cluster">
            {
                module.links.length > 0 &&
                    module.links.map((link, idx) => {
                        const href = link.href.sectionSlug
                            ? link.href.pageSlug.fullUrl
                            : link.href.pageSlug.current;
                        return idx === 0 ? (
                            <Button href={href} theme="white">
                                {link.name}
                            </Button>
                        ) : (
                            <a class="text-step--1" href={href}>
                                {link.name}
                            </a>
                        );
                    })
            }
        </div>
        {
            module.showFeaturedAnnouncement && (
                <FeaturedAnnouncement
                    links={featuredLinks}
                    text={module.featuredAnnouncement?.text}
                    title={module.featuredAnnouncement?.title}
                />
            )
        }
    </div>
    <div class="video-controls cluster">
        <Button
            className="icon-wrapper"
            id="playButton"
            style="none"
            theme="primary-light"
        >
            <span class="text-step--1">Pause</span>
            <i class="fa-duotone fa-play-pause"></i>
        </Button>
    </div>
    <div class="hero-bg">
        <div class="overlay"></div>
        <video
            autoplay
            controls
            id="home-video"
            loop
            muted
            playsinline
            poster={imagePoster.src}
            preload="auto"
            title="Panning aerial view of San Marino Community Church."
        >
            <source src="/home-bg-video.mp4" type="video/mp4" />
        </video>
    </div>
</article>

<style>
    .hero {
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: center;
        text-align: center;
        align-items: flex-start;
        min-height: clamp(70vh, 45rem, 80vh);
        padding-block-start: var(--space-3xl);
        padding-block-end: var(--space-3xl);
    }

    .flow {
        --flow-space: var(--space-m);
        align-items: center;
    }

    .video-controls {
        position: absolute;
        z-index: 25;
        right: 3rem;
        top: 2rem;
        color: white;
    }

    .icon-wrapper:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    .content-wrapper {
        position: relative;
        z-index: 3;
        width: 100%;
        color: var(--color-white);
    }

    .content-wrapper p {
        max-width: 66ch;
    }

    .hero-bg {
        overflow: hidden;
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        width: 100%;
        height: 100%;
    }

    .hero-bg .overlay {
        position: absolute;
        z-index: 1;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
    }

    .hero-bg video {
        position: relative;
        min-width: 100%;
        min-height: 100%;
        top: 50%;
        left: 50%;
        transform: translateX(-50%) translateY(-50%);
        width: auto;
        height: auto;
        z-index: -100;
        background-size: cover;
    }

    .hero-bg img {
        position: relative;
        object-fit: cover;
        z-index: 0;
    }
</style>

<script>
    const video = document.getElementById("home-video") as HTMLVideoElement;
    const playButton = document.querySelector("#playButton");
    const buttonText = playButton?.children[0];
    let playState = true;

    playButton?.addEventListener("click", () => {
        if (!playState) {
            video.play();
        } else {
            video.pause();
        }
        playState = !playState;
        if (buttonText) {
            buttonText.textContent = playState ? "Pause" : "Play";
        }
    });
</script>
