---
import { format, tzDate } from "@formkit/tempo";
import { type CollectionEntry } from "astro:content";
import Image from "astro/components/Image.astro";
import bgImage from "@assets/images/church-ext-2.jpg";
import getYouTubeId from "get-youtube-id";

interface Props {
    service: CollectionEntry<"services">;
    showVideoThumbnail?: boolean;
    align?: "left" | "right";
}

const { service, showVideoThumbnail = false, align = "left" } = Astro.props;

const date = tzDate(service.data.date, "America/Los_Angeles");

let description = `Watch video from our ${service.data.types.length > 1 ? "services" : "service"} on ${format(date, "full")}.`;

// TODO: fix mobile alignment styles
---

<a
    class="service-wrapper"
    data-align={align}
    data-layout={showVideoThumbnail ? "with-video" : "default"}
    href={`/worship/services/${service.data.slug}`}
>
    <div class="date-label-wrapper">
        <time class="date-label" datetime={service.data.date}>
            <div class="event-day font-header">
                {format(date, "D")}
            </div>
            <div class="event-month small-title">
                {format(date, "MMM")}
            </div>
        </time>
        <Image
            alt=""
            class="bgImage"
            format="webp"
            height={500}
            src={bgImage}
            width={500}
        />
    </div>
    <!-- <div class="date-label-mobile"></div> -->
    <div class="flow content">
        <header>
            <div class="small-title category">
                {service.data.types.map((t) => t.name).join(" & ")}
            </div>
            <h3 class="text-step-2">{service.data.name}</h3>
        </header>
        <p>{description}</p>
    </div>
    {
        showVideoThumbnail && service.data.types.length > 0 && (
            <div class="frame video">
                <div class="icon">
                    <svg
                        aria-hidden="true"
                        fill="var(--color-white)"
                        height="40"
                        viewBox="0 0 512 512"
                        width="40"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path d="M256 32a224 224 0 1 1 0 448 224 224 0 1 1 0-448zm0 480A256 256 0 1 0 256 0a256 256 0 1 0 0 512zm72.7-256L208 329.7V182.3L328.7 256zM212.5 147.5c-7.4-4.5-16.7-4.7-24.3-.5s-12.3 12.3-12.3 20.9V344c0 8.7 4.7 16.7 12.3 20.9s16.8 4.1 24.3-.5l144-88c7.1-4.4 11.5-12.1 11.5-20.5s-4.4-16.1-11.5-20.5l-144-88z" />
                    </svg>
                </div>
                <div class="overlay" />
                <Image
                    alt={`${service.data.types[0].name}`}
                    height={225}
                    src={`https://img.youtube.com/vi/${getYouTubeId(service.data.types[0].video)}/sddefault.jpg`}
                    width={300}
                />
            </div>
        )
    }
</a>

<style>
    .service-wrapper {
        text-decoration: none;
        display: grid;
        grid-template-columns: 1fr 3fr 2fr;
        align-items: center;
        gap: 2rem;
        padding: 0.5rem;
        border-radius: var(--rounded-corners);
        border: 2px solid transparent;
        transition: all 0.2s ease;

        &[data-layout="default"] {
            grid-template-columns: 1fr 3fr;
        }

        &[data-align="right"] {
            text-align: right;
            grid-template-columns: 3fr 1fr;

            & .content {
                order: -1;
            }
        }
    }

    .service-wrapper:hover {
        box-shadow: var(--shadow-large);
    }

    .date-label-wrapper {
        position: relative;
        border-radius: var(--rounded-corners);
        align-self: stretch;
        display: flex;
        flex-direction: column;
        justify-content: center;
        text-align: center;
        align-items: center;
        background-color: var(--color-primary-100);
        overflow: hidden;
    }

    .date-label {
        position: relative;
        padding: 1rem;
        z-index: 2;
    }

    .bgImage {
        position: absolute;
        z-index: 1;
        inset: 0;
        border-radius: var(--rounded-corners);
        filter: saturate(0);
        opacity: 1;
        mix-blend-mode: overlay;
        height: 100%;
        object-fit: cover;
    }

    .event-day {
        font-size: var(--step-5);
        color: var(--color-primary-800);
        line-height: 1;
    }

    .date-label .small-title {
        margin-top: 3px;
        color: var(--color-primary-800);
    }

    .small-title.category {
        font-size: 13px;
        display: inline-block;
        color: var(--color-primary-800);
        line-height: 1;
        padding: 4px 6px;
        margin-bottom: 8px;
        background-color: var(--color-primary-100);
        border-radius: var(--rounded-corners-small);
    }

    .date-label-mobile {
        display: none;
    }

    .date-label-mobile time {
        font-style: italic;
        font-variant-numeric: lining-nums;
        line-height: 1.15;
    }

    .frame {
        border-radius: var(--rounded-corners);
        max-width: 20rem;
        justify-self: end;
        position: relative;
    }

    .text-step-2 {
        margin-top: 6px;
    }

    .frame .icon {
        position: absolute;
        z-index: 2;
        inset: 0;
        display: flex;
        width: 100%;
        height: 100%;
        justify-content: center;
        align-items: center;
    }

    .frame .icon svg {
        transition: 0.2s all ease;
        opacity: 0;
    }

    .frame .overlay {
        position: absolute;
        inset: 0;
        opacity: 0.3;
        background: hsl(0deg 0% 0% / 10%);
        transition: 0.2s all ease-in;
    }

    a.service-wrapper:hover .frame .icon svg {
        transform: scale(1.25);
        opacity: 1;
    }

    a.service-wrapper:hover .frame .overlay {
        background: hsl(0deg 0% 0% / 80%);
    }

    a.service-wrapper:hover h3 {
        text-decoration: underline;
    }

    @media (max-width: 850px) {
        a.service-wrapper {
            grid-template-columns: 1fr 1fr 1fr;
            column-gap: 3rem;
            row-gap: 2rem;
            padding: 0;
        }

        a.service-wrapper:hover {
            box-shadow: none;
        }

        .date-label-wrapper {
            grid-column: 1/2;
            grid-row: 2/2;
        }

        .frame {
            grid-column: 1/4;
            grid-row: 1/1;
            width: 100%;
            max-width: none;
            justify-self: flex-start;
        }

        .content {
            grid-column: 2/4;
            grid-row: 2/2;
        }

        ul.flow {
            --flow-space: var(--space-2xl);
        }
    }

    @media (max-width: 768px) {
        .frame {
            max-width: none;
            justify-self: stretch;
        }

        a.service-wrapper {
            column-gap: 2rem;
            row-gap: 2rem;
        }

        ul.flow {
            --flow-space: var(--space-3xl);
        }
    }

    @media (max-width: 640px) {
        a.service-wrapper {
            column-gap: 1rem;
            row-gap: 1rem;
            grid-template-columns: repeat(4, 1fr);
        }

        .frame {
            grid-column: 1/5;
            grid-row: 1/1;
        }

        .date-label-mobile {
            display: block;
            grid-column: 1/5;
            grid-row: 2/2;
        }

        .content {
            grid-column: 1/5;
            grid-row: 3/3;
        }

        .small-title.category {
            background: none;
            padding: 0;
        }

        .date-label-wrapper {
            display: none;
        }
    }
</style>
