---
import "@styles/rich-text.css";
import { format, tzDate } from "@formkit/tempo";
import BreadcrumbAuto from "@components/BreadcrumbAuto.astro";
import Button from "@components/Button.astro";
import EventsCardList from "@components/Events/EventsCardList.astro";
import { Image } from "astro:assets";
import ImageBlock from "@components/modules/portableTextBlocks/ImageBlock.astro";
import Layout from "@layouts/Layout.astro";
import MiniPreviewCard from "@components/MiniPreviewCard.astro";
import { PortableText } from "astro-portabletext";
import SanityImage from "@components/SanityImage.astro";
import YoutubeBlock from "@components/modules/portableTextBlocks/YoutubeBlock.astro";
import bgImage from "@assets/images/church-ext-2.jpg";
import { getCollection } from "astro:content";
import { isRecentOrUpcoming } from "@utils/isRecentOrUpcoming";
import v from "voca";

export async function getStaticPaths() {
    const allEvents = await getCollection("events");
    const allMinistries = await getCollection("ministries");

    return allEvents.map((page) => {
        return {
            params: {
                event: `connect/events/${v.lowerCase(page.data.slug)}`,
            },
            props: { page, allEvents, allMinistries },
        };
    });
}

const { page, allEvents, allMinistries } = Astro.props;

const breadcrumbs = [
    {
        name: "Connect",
        href: "/connect",
    },
    {
        name: "Events",
        href: "/connect/events",
    },
    {
        name: page.data.name,
        current: true,
    },
];

// filter out current event and find recent or upcoming
const relatedEvents = allEvents
    .filter((item) => item.id !== page.id && isRecentOrUpcoming(item.data.date))
    .sort(() => Math.random() - 0.5)
    .slice(0, 3);

const readableDate = format(
    tzDate(page.data.date, "America/Los_Angeles"),
    "medium",
);

const associatedMinistry = allMinistries.find(
    (item) => item.id === page.data.associatedMinistry,
);

// image
let baseImageHeight = 0;
let baseImageWidth = 0;
let cropHeight = 0;
let croppedAspectRatio = 0;

// Set image dimensions based on whether user has set crop or not within Sanity -- graceful fallback if no crop is set
if (page.data.image) {
    // Set base height to image default
    baseImageHeight = page.data.image.asset.metadata.dimensions.height;
    // Set base width to image default
    baseImageWidth = page.data.image.asset.metadata.dimensions.height;
    // If crop is set, calculate a new crop height (assume width doesn't change). Get the crop percentage from Sanity metadata and subtrat it from base image height.
    cropHeight = page.data.image.crop
        ? baseImageHeight -
          (baseImageHeight * page.data.image.crop.top +
              baseImageHeight * page.data.image.crop.bottom)
        : baseImageHeight;
    // Get a new aspect ratio based on the crop height
    croppedAspectRatio = baseImageWidth / cropHeight;
}
---

<Layout
    meta={{
        title: `${page.data.name} • ${readableDate}`,
        description: page.data.preview ?? "",
        ogTitle: `${page.data.name} • ${readableDate}`,
        ogDescription: `Event on ${readableDate}. ${page.data.preview}`,
        ogImage: page.data.image,
    }}
>
    <main data-layout="detail" data-template="event" slot="main">
        <article>
            <BreadcrumbAuto navigation={breadcrumbs} />
            <div class="content-wrapper with-sidebar">
                <div class="main-panel flow">
                    <section class="header flow">
                        <div>
                            <div class="eyebrow cluster">
                                <a
                                    class="small-title heading-category"
                                    href={`/connect/events/${v.lowerCase(page.data.eventType?.slug)}`}
                                >
                                    <svg
                                        fill="var(--color-primary-800)"
                                        height="12"
                                        viewBox="0 0 448 512"
                                        width="12"
                                        xmlns="http://www.w3.org/2000/svg"
                                        ><path
                                            d="M9.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.2 288 416 288c17.7 0 32-14.3 32-32s-14.3-32-32-32l-306.7 0L214.6 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"
                                        ></path></svg
                                    >
                                    <span
                                        >{
                                            `${page.data.eventType?.name} Events`
                                        }</span
                                    >
                                </a>
                                <time
                                    class="small-title"
                                    datetime={format(
                                        tzDate(
                                            page.data.date,
                                            "America/Los_Angeles",
                                        ),
                                        "YYYY-MM-DD",
                                    )}
                                    >{
                                        format(
                                            tzDate(
                                                page.data.date,
                                                "America/Los_Angeles",
                                            ),
                                            "MMMM D, YYYY",
                                        )
                                    }</time
                                >
                            </div>
                            <h1 class="text-step-6">{page.data.name}</h1>
                        </div>
                        <p class="text-step-1"><em>{page.data.preview}</em></p>
                    </section>
                    {
                        page.data.image && (
                            <SanityImage
                                alt={page.data.image.asset.altText || ""}
                                aspectRatio={[baseImageWidth, cropHeight]}
                                class:list={["image-rounded"]}
                                loading="eager"
                                source={page.data.image}
                                width={900}
                            />
                        )
                    }
                    <section>
                        <div class="rich-text">
                            <PortableText
                                components={{
                                    type: {
                                        image: ImageBlock,
                                        youtube: YoutubeBlock,
                                    },
                                }}
                                value={page.data.richContent!}
                            />
                        </div>
                    </section>
                </div>
                <div>
                    <div class="sidebar-content">
                        <div class="event-box-wrapper">
                            <div class="event-box">
                                <div>
                                    <h2 class="text-step-2">Event Details</h2>
                                    <ul class="event-details flow">
                                        <li>
                                            <div class="small-title cluster">
                                                <svg
                                                    height="14"
                                                    viewBox="0 0 448 512"
                                                    width="14"
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    ><defs
                                                        ><style>
                                                            .fa-secondary {
                                                                opacity: 0.4;
                                                            }
                                                        </style></defs
                                                    ><path
                                                        class="fa-primary"
                                                        d="M160 32c0-17.7-14.3-32-32-32S96 14.3 96 32V64H48C21.5 64 0 85.5 0 112v80H448V112c0-26.5-21.5-48-48-48H352V32c0-17.7-14.3-32-32-32s-32 14.3-32 32V64H160V32z"
                                                    ></path><path
                                                        class="fa-secondary"
                                                        d="M0 192H448V464c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V192z"
                                                    ></path></svg
                                                >
                                                <span>Date</span>
                                            </div>
                                            <time class="text-step--1"
                                                >{
                                                    format(
                                                        tzDate(
                                                            page.data.date,
                                                            "America/Los_Angeles",
                                                        ),
                                                        {
                                                            date: "full",
                                                        },
                                                    )
                                                }</time
                                            >
                                        </li>
                                        <li>
                                            <div class="small-title cluster">
                                                <svg
                                                    height="14"
                                                    viewBox="0 0 512 512"
                                                    width="14"
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    ><defs
                                                        ><style>
                                                            .fa-secondary {
                                                                opacity: 0.4;
                                                            }
                                                        </style></defs
                                                    ><path
                                                        class="fa-primary"
                                                        d="M256 96c-13.3 0-24 10.7-24 24V256c0 8 4 15.5 10.7 20l96 64c11 7.4 25.9 4.4 33.3-6.7s4.4-25.9-6.7-33.3L280 243.2V120c0-13.3-10.7-24-24-24z"
                                                    ></path><path
                                                        class="fa-secondary"
                                                        d="M256 0a256 256 0 1 1 0 512A256 256 0 1 1 256 0zM232 120V256c0 8 4 15.5 10.7 20l96 64c11 7.4 25.9 4.4 33.3-6.7s4.4-25.9-6.7-33.3L280 243.2V120c0-13.3-10.7-24-24-24s-24 10.7-24 24z"
                                                    ></path></svg
                                                >
                                                <span>Time</span>
                                            </div>
                                            <time class="text-step--1"
                                                >{
                                                    format(
                                                        tzDate(
                                                            page.data.date,
                                                            "America/Los_Angeles",
                                                        ),
                                                        {
                                                            time: "short",
                                                        },
                                                    )
                                                }</time
                                            >
                                            {
                                                page.data.hasEndDate && (
                                                    <span class="text-step--1">
                                                        –{" "}
                                                        <time class="text-step--1">
                                                            {format(
                                                                tzDate(
                                                                    page.data
                                                                        .endDate!,
                                                                    "America/Los_Angeles",
                                                                ),
                                                                {
                                                                    time: "short",
                                                                },
                                                            )}
                                                        </time>
                                                    </span>
                                                )
                                            }
                                        </li>
                                        <li>
                                            <div class="small-title cluster">
                                                <svg
                                                    height="14"
                                                    viewBox="0 0 384 512"
                                                    width="14"
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    ><defs
                                                        ><style>
                                                            .fa-secondary {
                                                                opacity: 0.4;
                                                            }
                                                        </style></defs
                                                    ><path
                                                        class="fa-primary"
                                                        d="M192 144a48 48 0 1 0 0 96 48 48 0 1 0 0-96z"
                                                    ></path><path
                                                        class="fa-secondary"
                                                        d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 112a80 80 0 1 1 0 160 80 80 0 1 1 0-160z"
                                                    ></path></svg
                                                >
                                                <span>Location</span>
                                            </div>
                                            <div class="text-step--1">
                                                {page.data.location}
                                            </div>
                                        </li>
                                    </ul>
                                </div>
                                <Image
                                    alt=""
                                    class="img"
                                    format="webp"
                                    height={500}
                                    src={bgImage}
                                    width={500}
                                />
                            </div>
                            <div class="event-box-lower">
                                {
                                    associatedMinistry ? (
                                        <div class="flow">
                                            <div class="small-title">
                                                Associated Ministry
                                            </div>
                                            <MiniPreviewCard
                                                href={`/connect/ministries/${associatedMinistry.data.slug}`}
                                                image={
                                                    associatedMinistry.data
                                                        .image
                                                }
                                                theme="dark"
                                            >
                                                <div class="text-step-1 font-header">
                                                    {
                                                        associatedMinistry.data
                                                            .name
                                                    }
                                                </div>
                                            </MiniPreviewCard>
                                        </div>
                                    ) : (
                                        <a class="cluster" href="/calendar">
                                            <i class="fa-duotone fa-calendar-days" />
                                            See more events on our calendar.
                                        </a>
                                    )
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <section class="related-section" id="related-content">
                <div class="content-wrapper">
                    <div class="related-content flow">
                        {relatedEvents.length > 0 && (
                            <h2 class="text-step-3">Explore Recent & Upcoming Events</h2>
                            <EventsCardList events={relatedEvents} />
                        )}
                        <div class="center-items">
                            <Button
                                href="/connect/events"
                            >
                                See All Events
                            </Button>
                        </div>
                    </div>
                </div>
            </section>
        </article>
    </main>
</Layout>

<style>
    .with-sidebar {
        --sidebar-gap: 5rem;
        padding-block: var(--space-3xl);
    }

    .main-panel {
        --flow-space: 3rem;
    }

    .header {
        --flow-space: 2rem;
    }

    .cta {
        margin-block: var(--section-spacer-half);
    }

    .more {
        --flow-space: 2.5rem;
    }

    .responsive-grid {
        --gap: 2rem;
        --item-min-width: 20rem;
        --item-max-width: 23rem;
    }

    .location-footer.cluster {
        gap: 4px;
    }

    .location-footer .location-icon {
        display: flex;
    }

    .sidebar-content {
        padding-top: 1rem;
    }

    .eyebrow.cluster {
        margin-bottom: 1rem;
    }

    .eyebrow > :last-child {
        font-variant-numeric: lining-nums;
        color: var(--color-primary-800);
    }

    .small-title.heading-category {
        font-size: 14px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        color: var(--color-primary-800);
        width: fit-content;
        line-height: 1;
        padding: 6px 9px;
        background-color: var(--color-primary-100);
        border-radius: var(--rounded-corners-small);
        transition: all 0.2s ease;
    }

    .small-title.heading-category:hover {
        background-color: var(--color-primary-200);
    }

    .small-title.event-category {
        display: inline-block;
        color: var(--color-primary-900);
        line-height: 1;
        padding: 4px 6px;
        margin-bottom: 10px;
        background-color: var(--color-primary-100);
        border-radius: var(--rounded-corners-small);
    }

    .event-box-wrapper {
        --shadow: 0px 4px 40px hsl(217deg 87% 40% / 15%);
        box-shadow: var(--shadow);
        border-radius: var(--rounded-corners);
    }

    .event-box {
        position: relative;
        display: flex;
        flex-direction: column;
        padding: 2rem;
        border-top-left-radius: var(--rounded-corners);
        border-top-right-radius: var(--rounded-corners);
        background: var(--color-primary-100);
        overflow: hidden;
    }

    .event-box-lower {
        background: var(--color-primary-800);
        color: var(--color-white);
        padding: 2rem;
        border-bottom-left-radius: var(--rounded-corners);
        border-bottom-right-radius: var(--rounded-corners);
    }

    .event-box-lower .flow > :first-child {
        margin-bottom: 1rem;
    }

    .event-box-lower .font-header {
        line-height: 1.2;
    }

    .event-box > div {
        position: relative;
        z-index: 2;
    }

    .img {
        position: absolute;
        z-index: 1;
        inset: 0;
        border-radius: var(--rounded-corners);
        filter: saturate(0);
        opacity: 0.75;
        mix-blend-mode: overlay;
    }

    .event-details {
        margin-top: 1.5rem;
    }

    .event-details .small-title {
        color: var(--color-primary-800);
        margin-bottom: 3px;
    }

    .event-details .small-title.cluster {
        --cluster-space: 9px;
    }

    .event-details svg {
        fill: var(--color-primary-800);
    }

    .center-items {
        margin-top: var(--space-2xl);
    }

    .related-section {
        padding-block: var(--space-3xl);
        background-color: var(--color-primary-50);

        & .content-wrapper {
            padding-block: 0;
        }
    }

    .related-content {
        --flow-space: 2.5rem;
    }

    @media (max-width: 768px) {
        .related-content {
            --flow-space: 2rem;
        }

        .breadcrumb-wrapper {
            padding-inline-start: 1rem;
        }

        .content-wrapper.with-sidebar {
            --sidebar-gap: 2rem;
            padding-block: var(--space-xl);
        }

        .highlight-section {
            padding-block: var(--space-xl);
        }
    }
</style>
