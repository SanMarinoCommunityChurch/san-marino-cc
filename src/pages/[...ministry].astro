---
import "@styles/rich-text.css";
import { type CollectionEntry, getCollection } from "astro:content";
import { format, tzDate } from "@formkit/tempo";
import BreadcrumbAuto from "@components/BreadcrumbAuto.astro";
import Button from "@components/Button.astro";
import ContactAvatar from "@components/ContactAvatar.astro";
import ImageBlock from "@components/modules/portableTextBlocks/ImageBlock.astro";
import Layout from "@layouts/Layout.astro";
import MiniPreviewCard from "@components/MiniPreviewCard.astro";
import MinistriesList from "@components/ministries/MinistriesList.astro";
import { PortableText } from "astro-portabletext";
import SanityImage from "@components/SanityImage.astro";
import YoutubeBlock from "@components/modules/portableTextBlocks/YoutubeBlock.astro";
import { isRecentOrUpcoming } from "@utils/isRecentOrUpcoming";
import { joinNames } from "@utils/format";
import { sortUpcoming } from "@utils/sortEvents";
import v from "voca";

export async function getStaticPaths() {
    const allMinistries = await getCollection("ministries");
    const allMinistryCategories = await getCollection("ministryCategories");
    const relevantEvents = await getCollection("events", ({ data }) =>
        isRecentOrUpcoming(data.date),
    );
    const allPeople = await getCollection("people");

    return allMinistries.map((page) => {
        return {
            params: {
                ministry: `connect/ministries/${v.lowerCase(page.data.slug)}`,
            },
            props: {
                page,
                allMinistries,
                allMinistryCategories,
                relevantEvents,
                allPeople,
            },
        };
    });
}

const {
    page,
    allMinistries,
    allMinistryCategories,
    relevantEvents,
    allPeople,
} = Astro.props;

const breadcrumbs = [
    {
        name: "Connect",
        href: "/connect",
    },
    {
        name: "Ministries",
        href: "/connect/ministries",
    },
    {
        name: page.data.name,
        current: true,
    },
];

const category = allMinistryCategories.find(
    (item) => item.id === page.data.category,
);

let associatedEvents: CollectionEntry<"events">[] = [];
if (page.data.associatedEvents.length) {
    associatedEvents = relevantEvents.filter((e) =>
        page.data.associatedEvents?.some((v) => v._id === e.id),
    );
}
const sortedEvents = sortUpcoming(associatedEvents);

// filter out current ministry and find others w/ same category type
const relatedMinistries = allMinistries
    .filter(
        (item) =>
            item.id !== page.id && item.data.category === page.data.category,
    )
    .sort(() => Math.random() - 0.5)
    .slice(0, 3);

const contactPerson = allPeople.find(
    (item) => item.id === page.data.contactPerson,
);
---

<Layout
    meta={{
        title: page.data.name,
        description: `${page.data.category}. ${page.data.preview}`,
        ogTitle: page.data.name,
        ogDescription: `${page.data.category}. ${page.data.preview}`,
        ogImage: page.data.image || undefined,
    }}
>
    <main data-layout="detail" data-template="ministry" slot="main">
        <section
            class="hero"
        >
            <BreadcrumbAuto navigation={breadcrumbs} position="absolute" />
            <div class="content-wrapper flow">
                <div
                    class="eyebrow cluster"
                    slot="eyebrow"
                    style="margin-bottom: -0.5rem;"
                >
                    <a
                        class="small-title heading-category"
                        href={`/connect/ministries/${v.lowerCase(category?.data.slug)}`}
                    >
                        <svg
                            fill="var(--color-primary-800)"
                            height="12"
                            viewBox="0 0 448 512"
                            width="12"
                            xmlns="http://www.w3.org/2000/svg"
                            ><path
                                d="M9.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.2 288 416 288c17.7 0 32-14.3 32-32s-14.3-32-32-32l-306.7 0L214.6 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"
                            ></path></svg
                        >
                        <span>{category?.data.name}</span>
                    </a>
                </div>
                <h1 class="text-step-6">{page.data.name}</h1>
                {
                    page.data.preview && (
                        <p class="description">{page.data.preview}</p>
                    )
                }
            </div>
            <div class="overlay" />
        </section>
        <div class="content-wrapper with-sidebar">
            <article>
                <div class="main-panel flow">
                    {
                        page.data.image && (
                            <SanityImage
                                alt={page.data.image?.asset.altText || ""}
                                class:list={["image-rounded"]}
                                loading="eager"
                                source={page.data.image}
                                width={900}
                            />
                        )
                    }
                    <div class="rich-text">
                        <PortableText
                            components={{
                                type: {
                                    image: ImageBlock,
                                    youtube: YoutubeBlock,
                                },
                            }}
                            value={page.data.richContent}
                        />
                    </div>
                </div>
            </article>
            <div class="sidebar-content">
                {
                    contactPerson && (
                        <div>
                            <ContactAvatar
                                href={
                                    contactPerson.data.slug
                                        ? `/who-we-are/leadership/${contactPerson.data.slug}`
                                        : contactPerson.data.contact?.email
                                          ? `mailto:${contactPerson.data.contact.email}`
                                          : undefined
                                }
                                image={contactPerson.data.image}
                                name={joinNames(contactPerson.data.name)}
                            />
                        </div>
                    )
                }
                {
                    sortedEvents.length > 0 && (
                        <section class="associated-events flow">
                            <h2 class="text-step-2">Associated Events</h2>
                            <ul class="flow" style="--flow-space: 2rem;">
                                {sortedEvents.map((event) => (
                                    <li class="cluster">
                                        <MiniPreviewCard
                                            href={`/connect/events/${event.data.slug}`}
                                            image={event.data.image}
                                        >
                                            <div class="text-step-1 font-header">
                                                {event.data.name}
                                            </div>
                                            <time
                                                class="small-title"
                                                datetime={format(
                                                    tzDate(
                                                        event.data.date,
                                                        "America/Los_Angeles",
                                                    ),
                                                    "YYYY-MM-DD",
                                                )}
                                            >
                                                {format(
                                                    tzDate(
                                                        event.data.date,
                                                        "America/Los_Angeles",
                                                    ),
                                                    "long",
                                                )}
                                            </time>
                                        </MiniPreviewCard>
                                    </li>
                                ))}
                            </ul>
                        </section>
                    )
                }
            </div>
        </div>
        <section class="related-section" id="related-content">
            <div class="content-wrapper">
                <div class="related-content flow">
                    {relatedMinistries.length > 0 && (
                        <h2 class="text-step-3">Explore Related Ministries</h2>
                        <MinistriesList ministries={relatedMinistries} />
                    )}
                    <div class="center-items">
                        <Button
                            href={`/connect/ministries/${v.lowerCase(category?.data.slug)}`}
                        >
                            See All {category?.data.name}
                        </Button>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .hero {
        position: relative;
        padding-top: 12rem;
        padding-bottom: var(--space-2xl);
        color: var(--color);
        /* background: var(--color-primary-100); */
        background: var(--color-primary-100);
    }

    .hero .content-wrapper {
        z-index: 2;
    }

    .hero .content-wrapper.flow {
        --flow-space: var(--space-m);
    }

    .hero p {
        max-width: 69ch;
    }

    .hero .overlay {
        display: var(--display);
        position: absolute;
        -webkit-mask-image: linear-gradient(to bottom, black, transparent 60%);
        mask-image: linear-gradient(to bottom, black, transparent 60%);
        inset: 0;
        opacity: 0.05;
