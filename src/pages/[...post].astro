---
import "@styles/rich-text.css";
import { addMonth, format, isAfter, tzDate } from "@formkit/tempo";
import BreadcrumbAuto from "@components/BreadcrumbAuto.astro";
import Button from "@components/Button.astro";
import Category from "@components/Category.astro";
import ContactAvatar from "@components/ContactAvatar.astro";
import ImageBlock from "@components/modules/portableTextBlocks/ImageBlock.astro";
// import InlineEvent from "@components/InlineEvent.astro";
import Layout from "@layouts/Layout.astro";
// import MiniPreviewCard from "@components/MiniPreviewCard.astro";
import { PortableText } from "astro-portabletext";
import PostsList from "@components/posts/PostsList.astro";
import PreviewFeatureBlock from "@components/modules/portableTextBlocks/PreviewFeatureBlock.astro";
import SanityImage from "@components/SanityImage.astro";
import YoutubeBlock from "@components/modules/portableTextBlocks/YoutubeBlock.astro";
import { getCollection } from "astro:content";
// import bgImage from "@assets/images/church-ext-2.jpg";
import { joinNames } from "@utils/format";
import v from "voca";

export async function getStaticPaths() {
    const allPosts = await getCollection("posts");
    const allCategories = await getCollection("postCategories");
    const allPeople = await getCollection("people");

    return allPosts.map((page) => {
        return {
            params: {
                post: `resources/${v.lowerCase(page.data.slug)}`,
            },
            props: {
                page,
                posts: allPosts,
                categories: allCategories,
                people: allPeople,
            },
        };
    });
}

const { page, posts, categories, people } = Astro.props;

const postCategory = categories.find((c) => c.id === page.data.categoryRef);
const author = people.find((p) => p.id === page.data.authorRef);

const breadcrumbs = [
    {
        name: "Resources",
        href: "/resources",
    },
    {
        name: postCategory?.data.name ?? "",
        href: `/resources/${postCategory?.data.slug}`,
    },
    {
        name: page.data.name,
        current: true,
    },
];

// filter by same category & date within last 6 months
const now = new Date();
const relatedPosts = posts
    .filter(
        (post) =>
            post.data.name !== page.data.name &&
            post.data.categoryRef === page.data.categoryRef && isAfter(tzDate(post.data.date, "America/Los_Angeles"), addMonth(now, -6)),
    )
    .sort(() => Math.random() - 0.5)
    .slice(0, 3);
---

<Layout
    meta={{
        title: page.data.seo.title ?? page.data.name,
        description: page.data.seo.description ?? page.data.preview,
        ogTitle: page.data.seo.ogTitle ?? page.data.seo.title ?? page.data.name,
        ogDescription:
            page.data.seo.ogDescription ??
            page.data.seo.description ??
            page.data.preview,
        ogImage: page.data.seo.ogImage,
    }}
>
    <main data-layout="detail" data-template="post" slot="main">
        <article>
            <BreadcrumbAuto navigation={breadcrumbs} />
            <div class="overlay"></div>
            <div class="content-wrapper">
                <header class="header flow">
                    <div>
                        <Category
                            href={`/resources/${postCategory?.data.slug}`}
                            name={postCategory?.data.name}
                            size="small"
                        />
                        <h1 class="text-step-5 heading">{page.data.name}</h1>
                    </div>
                    <div class="cluster info">
                        <time class="post-date" datetime={page.data.date}
                            >{
                                format(
                                    tzDate(
                                        page.data.date,
                                        "America/Los_Angeles",
                                    ),
                                    "long",
                                )
                            }</time
                        >
                        {
                            author && (
                                <ContactAvatar
                                    heading="Posted by"
                                    href={
                                        author.data.slug
                                            ? `/who-we-are/leadership/${author.data.slug}`
                                            : author.data.contact?.email
                                              ? `mailto:${author.data.contact.email}`
                                              : undefined
                                    }
                                    image={author.data.image}
                                    name={joinNames(author.data.name)}
                                    size="small"
                                />
                            )
                        }
                    </div>
                    <p class="text-step-1"><em>{page.data.preview}</em></p>
                </header>
                {
                    page.data.image && (
                        <SanityImage
                            alt={page.data.image?.asset.altText || ""}
                            aspectRatio={[16, 9]}
                            class:list={["image"]}
                            source={page.data.image}
                            width={1200}
                        />
                    )
                }
                <div class="rich-text">
                    <PortableText
                        components={{
                            type: {
                                image: ImageBlock,
                                previewFeature: PreviewFeatureBlock,
                                youtube: YoutubeBlock,
                                // event: InlineEvent,
                            },
                        }}
                        value={page.data.richContent}
                    />
                </div>
            </div>
            <section class="related-section" id="related-content">
                <div class="content-wrapper">
                    <div class="related-content flow">
                        {relatedPosts.length > 0 && (
                            <h2 class="text-step-3">Explore Related Posts</h2>
                            <PostsList posts={relatedPosts} />
                        )}
                        <div class="center-items">
                            <Button
                                href={`/resources/${v.lowerCase(postCategory?.data.slug)}`}
                            >
                                See all {postCategory?.data.name} Posts
                            </Button>
                        </div>
                    </div>
                </div>
            </section>
        </article>
    </main>
</Layout>

<style>
    .relative {
        position: relative;
    }

    .heading {
        margin-top: 9px;
    }

    .content-wrapper {
        padding-block: var(--space-3xl);
    }

    .cluster.info {
        --cluster-space: 3rem;
    }

    .image {
        border-radius: var(--rounded-corners);
        margin-block: var(--space-2xl);
        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
    }

    .header p {
        max-width: var(--paragraph-measure);
    }

    .post-date {
        font-variant-numeric: lining-nums;
        font-family: var(--font-secondary);
        font-weight: var(--font-weight-semi);
        font-size: var(--step--1);
        letter-spacing: 1.5pt;
        text-transform: uppercase;
    }

    .overlay {
        position: absolute;
        -webkit-mask-image: linear-gradient(to bottom, black, transparent 60%);
        mask-image: linear-gradient(to bottom, black, transparent 60%);
        inset: 0;
        z-index: -1;
        height: 350px;
        opacity: 0.05;
