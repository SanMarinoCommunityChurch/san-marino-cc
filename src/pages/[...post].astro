    }

    .header.flow {
        --flow-space: 2rem;
    }

    .header {
        align-items: center;
    }

    .header :not(.info) {
        text-align: center;
    }

    .content {
        display: grid;
        grid-template-columns: 1fr 4fr;
        gap: 2rem;
    }

    .breadcrumb-wrapper {
        position: relative;
        z-index: 10;
        padding-inline-start: var(--space-l);
        top: 1rem;
        width: fit-content;
    }

    .related-section {
        padding-block: var(--space-3xl);
        background-color: var(--color-primary-50);

        & .content-wrapper {
            padding-block: 0;
        }
    }

    .related-content {
        --flow-space: 2.5rem;
    }

    @media (max-width: 768px) {
        .breadcrumb-wrapper {
            padding-inline-start: 1rem;
        }

        .highlight-section {
            padding-block: var(--space-xl);
        }

        .related-content {
            --flow-space: 2rem;
        }
    }

    @media (max-width: 640px) {
        .cluster.info {
            flex-direction: column;
            --align: center;
            --cluster-space: 1rem;
        }
    }
</style>
